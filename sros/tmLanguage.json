{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Nokia SR OS",
	"scopeName": "source.sros",
	"patterns": [
		{ "include": "#comment" },
		{ "include": "#persistent-indices" }
	],
	"repository": {
		"comment": {
			"match": "^\\s*#.*$",
			"name": "comment.line.number-sign.sros"
		},
		"persistent-indices": {
			"begin": "\\b(persistent-indices)\\s*\\{",
			"beginCaptures": {
				"1": { "name": "comment.block.persistent-indices.sros" }
			},
			"end": "\\}",
			"name": "comment.block.persistent-indices.sros",
			"patterns": [
				{ "include": "#persistent-indices" },
				{ "match": "[^{}]+", "name": "comment.block.persistent-indices.sros" }
			]
		}
	}
}
